{
  "name": "church-finance",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api:dev": "wrangler dev --port 8787",
    "cf:dev": "vite build && wrangler dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cf:deploy": "npm run build && wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply church-finance --local",
    "d1:migrate:remote": "wrangler d1 migrations apply church-finance --remote",
    "import:members:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/import-members-from-access.ps1",
    "import:members:remote": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/import-members-from-access.ps1 -Remote"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260414.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.82.2"
  }
}
